---
const { class: className } = Astro.props
---

<style>
  svg {
    position: relative;
    display: block;
    margin-inline: auto;
    color: white;
  }

  text {
    transform-origin: center;
  }

  .go-down-btn text {
    animation: rotate-btn 25s linear infinite;
  }

  @keyframes rotate-btn {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<div class={`go-down-btn ${className}`}>
  <svg
    version="1.1"
    xmlns="http://www.w3.org/2000/svg"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    width="200px"
    height="200px"
    viewBox="0 0 100 100"
    enable-background="new 0 0 100 100"
    xml:space="preserve"
  >
    <path
      id="textPath"
      fill="none"
      d="M89.322,50.197c0,22.09-17.91,40-40,40c-22.089,0-40-17.91-40-40 c0-22.089,17.911-40,40-40C71.412,10.197,89.322,28.108,89.322,50.197z"
    ></path>
    <text class="fill-white font-bold">
      <textPath xlink:href="#textPath"
        ><tspan dx="12" class="text-[0.7rem]"
          >YOU <tspan dx="12" class="text-[0.7rem]">LIVE</tspan>
          <tspan dx="12" class="text-[0.7rem]">WHAT</tspan>
          <tspan dx="12" class="text-[0.7rem]">YOU'VE</tspan>
          <tspan dx="12" class="text-[0.7rem]">LEARNED</tspan>
        </tspan>
      </textPath>
    </text>
  </svg>
</div>
