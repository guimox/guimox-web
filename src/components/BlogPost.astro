---
// src/components/BlogPost.astro
const { 
  title, 
  description, 
  pubDate, 
  heroImage, 
  url 
} = Astro.props;
---

<article class="blog-post-preview">
  {heroImage && (
    <img src={heroImage} alt={title} class="post-hero-image" />
  )}
  <div class="post-content">
    <h2>
      <a href={url}>{title}</a>
    </h2>
    <time datetime={pubDate.toISOString()}>
      {pubDate.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
    </time>
    <p>{description}</p>
  </div>
</article>

<style>
  .blog-post-preview {
    margin-bottom: 2rem;
    border-bottom: 1px solid #ddd;
    padding-bottom: 1rem;
  }
  .post-hero-image {
    max-width: 100%;
    height: auto;
    margin-bottom: 1rem;
  }
  .post-content h2 a {
    text-decoration: none;
    color: #333;
  }
  .post-content h2 a:hover {
    color: #666;
  }
</style>