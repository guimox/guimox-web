---
import { Icon } from 'astro-icon/components'
import ThemeIcon from './theme-icon.astro'
const { current } = Astro.props
---

<style>
  header {
    transition:
      max-width 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      margin 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  header nav {
    width: 1580px;
    max-width: 1580px;
    margin: 0;
    transition:
      max-width 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      margin 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  header.scrolled nav {
    max-width: 1280px;
    margin: 0 auto;
  }

  header.no-transition,
  header.no-transition nav {
    transition: none !important;
  }
</style>

<header
  class="no-transition inset-x-0 z-50 mx-auto flex h-[4.5rem] w-full animate-slide-down justify-center py-8 transition-colors duration-300 ease-in-out xl:px-8"
>
  <nav class="z-20 flex w-full items-center justify-between font-bold">
    <ul class="flex gap-6 text-base sm:text-lg">
      <li>
        <a class={`hover:opacity-50 transition-all ${current === 'guimox' ? 'text-color dark' : ''}`} href="/">
          Guimox
        </a>
      </li>
      <li>
        <a class={`hover:opacity-50 transition-all ${current === 'about' ? 'text-color dark' : ''}`} href="/about">
          About
        </a>
      </li>
      <li>
        <a class={`hover:opacity-50 transition-all ${current === 'blog' ? 'text-color dark' : ''}`} href="/blog">
          Projects
        </a>
      </li>
    </ul>
    <div class="flex w-fit gap-4">
      <Icon
        name="mdi:web"
        class="z-50 cursor-pointer text-2xl text-black transition duration-300 ease-in-out hover:opacity-50 focus:ring-2 dark:block dark:text-white"
      />
      <ThemeIcon />
    </div>
  </nav>
</header>
