---
import Rotate from './rotate.astro'
import TextH1 from './text/text-h1.astro'
import TextH3 from './text/text-h3.astro'
import TextParagraph from './text/text-paragraph.astro'
---

<nav class="flex w-full items-center justify-between p-4">
  <p class="cursor-pointer font-medium underline underline-offset-4 transition-all hover:opacity-50">Simplify</p>
  <ul class="flex w-fit justify-end gap-4">
    <li class="cursor-pointer font-medium underline underline-offset-4 transition-all hover:opacity-50">Blog</li>
    <li class="cursor-pointer font-medium underline underline-offset-4 transition-all hover:opacity-50">
      Projects
    </li>
  </ul>
</nav>

<div class="m-4 my-auto flex h-[45rem] flex-col items-end gap-10 rounded-md bg-color p-8 md:my-10 md:flex-row">
  <div class="flex h-full w-1/2 flex-col justify-between">
    <div>
      <TextH1 classs="text-white">GUILHERME LOPES</TextH1>
      <TextH1 classs="text-color-dark">FULLSTACK DEVELOPER</TextH1>
    </div>
    <div class="flex w-full justify-start">
      <Rotate />
    </div>
  </div>
  <div class="mb-0 flex h-3/5 flex-col items-end justify-between md:w-1/2">
    <TextH3 classs="md:text-right">
      Experienced software developer capable of working and exploring frontend and backend. Passionate about web
      accessibility, design systems, and creating seamless user experiences.
    </TextH3>
    <div class="mb-0 mr-0 flex items-end">
      <div class="transform-origin-bottom-left flex -rotate-90 flex-col">
        <TextParagraph>2024</TextParagraph>
        <TextParagraph>Madrid</TextParagraph>
      </div>
    </div>
  </div>
</div>
