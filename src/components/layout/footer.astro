---
import { Icon } from 'astro-icon/components'
---

<footer class="mx-auto flex w-full max-w-[1000px] justify-between py-4 pt-40">
  <p id="year" class="flex items-center gap-2 text-start text-sm">
    Simplicity is <Icon name="mdi:key" class="text-color" />
  </p>
  <div class="flex justify-end gap-3">
    <a href="https://github.com/guimox" target="_blank" aria-label="link to open my GitHub">
      <Icon name="mdi:github" class="cursor-pointer text-3xl transition-all duration-300 hover:opacity-50" />
    </a>
    <a href="https://www.linkedin.com/in/guimox" target="_blank" aria-label="link to open my LinkedIn">
      <Icon name="mdi:linkedin" class="cursor-pointer text-3xl transition-all duration-300 hover:opacity-50" />
    </a>
  </div>
</footer>
