---
import Duck from '../components/duck/duck.astro'
import TextH1 from '../components/text/text-h1.astro'
import TextH3 from '../components/text/text-h3.astro'
import TextParagraph from '../components/text/text-paragraph.astro'
---

<div class="flex flex-col-reverse items-center md:flex-row">
  <div class="my-4 flex w-full flex-col gap-2 sm:my-14">
    <TextH1><span class="text-color">Guilherme Lopes</span></TextH1>
    <TextH3 bold>Software Developer</TextH3>
    <div class="w-full sm:w-[85%]">
      <TextParagraph>
        Experienced software developer capable of working on the frontend and backend. Interested about anything
        that is related to web (CI/CD, Docker, databases, frontend, backend and cool stuff). <b
          >Passionate about improving & trying things</b
        >.
      </TextParagraph>
    </div>
  </div>
  <div
    class="flex h-full w-full items-center justify-center overflow-hidden rounded-md bg-color hover:scale-110 dark:bg-[#6666] sm:w-fit"
  >
    <Duck />
  </div>
</div>
